# dump1090 connection
DUMP1090_HOST=127.0.0.1
DUMP1090_PORT=30003

# HTTP server
HTTP_HOST=0.0.0.0
HTTP_PORT=8000

# Aircraft considered stale after this many seconds
AIRCRAFT_STALE_SECONDS=60

# Gap between sightings that ends a flight (seconds)
FLIGHT_GAP_SECONDS=600

# Database file
DATABASE_PATH=data/flight_tracker.db

# Data retention (hours)
RETENTION_HOURS=24

# API key for authenticating clients (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
API_KEY=replace-me-with-a-strong-secret
